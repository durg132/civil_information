            "concepts": [
              {
                "id": 1010101,
                "title": "Ductile Detailing (IS 13920)",
                "lesson": "IS 13920 ensures that RC frames can dissipate energy during earthquakes by requiring closely-spaced stirrups, 135° hooks, and minimum column-bar diameters. It limits axial stress (P_u/A_g f_ck ≤ 0.4) and mandates strong-column weak-beam hierarchy.",
                "quiz": [
                  { "q": "Maximum allowable axial stress ratio in a ductile column?", "opts": ["0.3", "0.4", "0.5", "0.6"], "ans": 1 },
                  { "q": "Hook angle for stirrup end as per IS 13920?", "opts": ["90°", "135°", "180°", "45°"], "ans": 1 },
                  { "q": "Minimum grade of concrete for ductile frame?", "opts": ["M20", "M25", "M30", "M35"], "ans": 2 },
                  { "q": "Strong-column weak-beam rule avoids which failure?", "opts": ["Soft-storey", "Column sway", "Beam hinge", "P-Δ"], "ans": 0 },
                  { "q": "Maximum stirrup spacing in critical region?", "opts": ["6 d_b", "8 d_b", "10 d_b", "12 d_b"], "ans": 0 }
                ]
              },
              {
                "id": 1010102,
                "title": "Flat-Slab & Shear-Wall Interaction",
                "lesson": "Flat-slabs give architectural flexibility but suffer from punching shear around columns. Introducing shear-walls reduces inter-storey drift to ≤ 0.12 % (IS 1893). Drop panels & column heads increase punching capacity by 30-40 %.",
                "quiz": [
                  { "q": "Primary failure mode of flat-slab under lateral load?", "opts": ["Flexure", "Punching shear", "Deflection", "Axial"], "ans": 1 },
                  { "q": "Max inter-storey drift for RC building (IS 1893)?", "opts": ["0.4 %", "0.2 %", "0.12 %", "0.08 %"], "ans": 2 },
                  { "q": "Drop panel increases which capacity?", "opts": ["Flexure", "Punching", "Compression", "Torsion"], "ans": 1 },
                  { "q": "Shear-wall aspect ratio for cantilever action?", "opts": ["≥ 1", "≥ 2", "≥ 3", "≥ 4"], "ans": 1 },
                  { "q": "Flat-slab thickness ≥ span / ?", "opts": ["24", "28", "32", "36"], "ans": 2 }
                ]
              }
            ]
          },
          {
